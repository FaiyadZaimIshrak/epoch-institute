<script>
// ── Section management ────────────────────────────────────────────────────────
var ALL_COMM_SECTIONS = ['community-page', 'opinions-page', 'articles-page', 'article-detail'];

function showCommSection(id) {
  ALL_COMM_SECTIONS.forEach(function(s) {
    var el = document.getElementById(s);
    if (!el) return;
    if (s === id) {
      el.classList.add('active');
      el.classList.remove('section-enter');
      el.offsetHeight; // reflow
      el.classList.add('section-enter');
    } else {
      el.classList.remove('active', 'section-enter');
    }
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Data state ────────────────────────────────────────────────────────────────
var _allOpinions       = [];
var _confirmedArticles = [];
var _opinionsPage      = 1;
var _articlesPage      = 1;
var _dataLoaded        = false;
var OPINIONS_PER_PAGE  = 20;
var OPINIONS_PREVIEW   = 3;
var ARTICLES_PER_PAGE  = 20;
var ARTICLES_PREVIEW   = 6;

// ── Opinions ──────────────────────────────────────────────────────────────────
function loadOpinions() {
  if (!EPOCH_API_URL || EPOCH_API_URL.includes('PASTE')) {
    document.getElementById('opinions-loading').style.display = 'none';
    return;
  }
  jsonp(EPOCH_API_URL + '?action=opinions', function(data) {
    _allOpinions = Array.isArray(data) ? data : [];
    renderOpinionsPreview();
  });
}

function renderOpinionItem(op, idx) {
  var date = op.ts ? new Date(op.ts).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' }) : '';
  return '<div class="opinion-item" style="animation-delay:' + (idx * 0.06) + 's">' +
    '<span class="opinion-item-name">' + escHtml(op.name) + '</span>' +
    '<p class="opinion-item-text">' + escHtml(op.text) + '</p>' +
    (date ? '<span class="opinion-item-date">' + date + '</span>' : '') +
  '</div>';
}

function renderOpinionsPreview() {
  var container = document.getElementById('opinions-list');
  var loading   = document.getElementById('opinions-loading');
  var empty     = document.getElementById('opinions-empty');
  var viewMore  = document.getElementById('opinions-view-more');
  loading.style.display = 'none';
  if (!_allOpinions.length) { empty.style.display = 'block'; viewMore.style.display = 'none'; return; }
  empty.style.display = 'none';
  container.innerHTML = _allOpinions.slice(0, OPINIONS_PREVIEW).map(renderOpinionItem).join('');
  viewMore.style.display = _allOpinions.length > OPINIONS_PREVIEW ? 'block' : 'none';
}

function openOpinionsPage() {
  _opinionsPage = 1;
  showCommSection('opinions-page');
  renderOpinionsPage();
}

function renderOpinionsPage() {
  var list  = document.getElementById('opinions-page-list');
  var pager = document.getElementById('opinions-pagination');
  var start = (_opinionsPage - 1) * OPINIONS_PER_PAGE;
  var slice = _allOpinions.slice(start, start + OPINIONS_PER_PAGE);
  var total = Math.ceil(_allOpinions.length / OPINIONS_PER_PAGE);
  list.innerHTML = slice.map(renderOpinionItem).join('');
  pager.innerHTML = buildPagination(total, _opinionsPage, 'goOpinionsPage');
}

function goOpinionsPage(p) {
  _opinionsPage = p;
  renderOpinionsPage();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Articles ──────────────────────────────────────────────────────────────────
function loadConfirmedArticles() {
  if (!EPOCH_API_URL || EPOCH_API_URL.includes('PASTE')) {
    document.getElementById('blog-loading').style.display = 'none';
    document.getElementById('blog-empty').style.display = 'block';
    return;
  }
  jsonp(EPOCH_API_URL + '?action=confirmed_articles', function(data) {
    _confirmedArticles = Array.isArray(data) ? data : [];
    renderArticlesPreview();
  });
}

function renderArticleCard(a, globalIdx, delay) {
  var date    = a.ts ? new Date(a.ts).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' }) : '';
  var excerpt = a.content && a.content.length ? a.content[0].slice(0, 180) + (a.content[0].length > 180 ? '…' : '') : '';
  return '<div class="blog-card" style="animation-delay:' + (delay * 0.07) + 's" onclick="openArticleDetailPage(' + globalIdx + ')">' +
    '<h4 class="blog-card-title">' + escHtml(a.title || 'Untitled') + '</h4>' +
    (excerpt ? '<p class="blog-card-excerpt">' + escHtml(excerpt) + '</p>' : '') +
    '<p class="blog-card-meta">' + date + '</p>' +
  '</div>';
}

function renderArticlesPreview() {
  var grid    = document.getElementById('blog-grid');
  var loading = document.getElementById('blog-loading');
  var empty   = document.getElementById('blog-empty');
  var seeMore = document.getElementById('blog-see-more');
  loading.style.display = 'none';
  if (!_confirmedArticles.length) { empty.style.display = 'block'; return; }
  grid.innerHTML = _confirmedArticles.slice(0, ARTICLES_PREVIEW).map(function(a, i) { return renderArticleCard(a, i, i); }).join('');
  if (_confirmedArticles.length > ARTICLES_PREVIEW) {
    seeMore.textContent = 'See All Articles →';
    seeMore.style.display = 'block';
  }
}

function openArticlesPage() {
  _articlesPage = 1;
  showCommSection('articles-page');
  renderArticlesPage();
}

function renderArticlesPage() {
  var grid  = document.getElementById('articles-page-grid');
  var pager = document.getElementById('articles-pagination');
  var empty = document.getElementById('articles-page-empty');
  var start = (_articlesPage - 1) * ARTICLES_PER_PAGE;
  var slice = _confirmedArticles.slice(start, start + ARTICLES_PER_PAGE);
  var total = Math.ceil(_confirmedArticles.length / ARTICLES_PER_PAGE);
  if (!slice.length) { empty.style.display = 'block'; grid.innerHTML = ''; pager.innerHTML = ''; return; }
  grid.innerHTML = slice.map(function(a, i) { return renderArticleCard(a, start + i, i); }).join('');
  pager.innerHTML = buildPagination(total, _articlesPage, 'goArticlesPage');
}

function goArticlesPage(p) {
  _articlesPage = p;
  renderArticlesPage();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function openArticleDetailPage(idx) {
  var a = _confirmedArticles[idx];
  if (!a) return;
  document.getElementById('article-detail-title').textContent = a.title || 'Untitled';
  document.getElementById('article-detail-meta').textContent  = a.ts
    ? new Date(a.ts).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
  document.getElementById('article-detail-body').innerHTML = (a.content || []).map(function(p) {
    return '<p>' + escHtml(p) + '</p>';
  }).join('');
  var fromArticles = document.getElementById('articles-page').classList.contains('active');
  ['article-detail-back', 'article-detail-back-bottom'].forEach(function(id) {
    document.getElementById(id).dataset.from = fromArticles ? 'articles' : 'community';
  });
  showCommSection('article-detail');
}

function closeArticleDetail() {
  var from = document.getElementById('article-detail-back').dataset.from;
  if (from === 'articles') { showCommSection('articles-page'); renderArticlesPage(); }
  else { showCommSection('community-page'); }
}

// ── Load on init ──────────────────────────────────────────────────────────────
function loadCommunityData() {
  if (_dataLoaded) return;
  _dataLoaded = true;
  loadConfirmedArticles();
  loadOpinions();
}
loadCommunityData();

// ── Event wiring ──────────────────────────────────────────────────────────────
document.getElementById('opinions-view-more').addEventListener('click', openOpinionsPage);
document.getElementById('blog-see-more').addEventListener('click', openArticlesPage);
document.getElementById('opinions-page-back').addEventListener('click', function() { showCommSection('community-page'); });
document.getElementById('articles-page-back').addEventListener('click', function() { showCommSection('community-page'); });
document.getElementById('article-detail-back').addEventListener('click', closeArticleDetail);
document.getElementById('article-detail-back-bottom').addEventListener('click', closeArticleDetail);

// ── Share modal ───────────────────────────────────────────────────────────────
var _shareFile = null;

document.getElementById('open-share-btn').addEventListener('click', function() {
  document.getElementById('share-modal').classList.add('is-open');
  document.body.style.overflow = 'hidden';
});

function closeShareModal() {
  document.getElementById('share-modal').classList.remove('is-open');
  document.body.style.overflow = '';
}
document.getElementById('share-modal-close').addEventListener('click', closeShareModal);
document.getElementById('share-modal').addEventListener('click', function(e) {
  if (e.target === e.currentTarget) closeShareModal();
});

// Drop zone
(function() {
  var zone     = document.getElementById('drop-zone');
  var fileInput = document.getElementById('sf-file');
  var label    = document.getElementById('drop-zone-filename');

  function setFile(file) {
    if (!file || !file.name.toLowerCase().endsWith('.docx')) {
      alert('Please select a .docx file.');
      return;
    }
    _shareFile = file;
    label.textContent = '📄 ' + file.name;
    label.style.display = 'block';
  }

  fileInput.addEventListener('change', function() { if (this.files[0]) setFile(this.files[0]); });
  zone.addEventListener('dragover',  function(e) { e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', function()  { zone.classList.remove('dragover'); });
  zone.addEventListener('drop', function(e) {
    e.preventDefault(); zone.classList.remove('dragover');
    if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
  });
})();

// Profession → affiliation row
document.getElementById('sf-profession').addEventListener('change', function() {
  var needsAffil = ['Teacher', 'Student', 'Researcher', 'Academic'].indexOf(this.value) !== -1;
  var optlAffil  = ['Healthcare Professional', 'Engineering Professional', 'Public Service', 'Private Service', 'Other'].indexOf(this.value) !== -1;
  var row = document.getElementById('sf-affil-row');
  row.style.display = (needsAffil || optlAffil) ? 'flex' : 'none';
  document.getElementById('sf-affil').required = needsAffil;
  document.getElementById('sf-affil-star').style.display = needsAffil ? '' : 'none';
});

// Share form submit
document.getElementById('share-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var name  = document.getElementById('sf-name').value.trim();
  var prof  = document.getElementById('sf-profession').value;
  var affil = document.getElementById('sf-affil').value.trim();
  var email = document.getElementById('sf-email').value.trim();
  var affilReq = ['Teacher', 'Student', 'Researcher', 'Academic'].indexOf(prof) !== -1;
  var ok = true;

  [['sf-name', !name], ['sf-profession', !prof],
   ['sf-affil', affilReq && !affil], ['sf-email', !isValidEmail(email)],
   ['drop-zone', !_shareFile]].forEach(function(pair) {
    var el = document.getElementById(pair[0]);
    if (el) el.classList.toggle('form-input-error', pair[1]);
    if (pair[1]) ok = false;
  });

  if (!ok) return;

  var reader = new FileReader();
  reader.onload = function() {
    var base64 = reader.result.split(',')[1];
    fetch(EPOCH_API_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        type: 'article', name: name, profession: prof, affil: affil, email: email,
        title: _shareFile.name.replace(/\.docx$/i, ''),
        filename: _shareFile.name, fileBase64: base64
      })
    }).catch(function() {});
    document.getElementById('sf-success').style.display = 'block';
    _shareFile = null;
  };
  reader.readAsDataURL(_shareFile);
});

// ── Opinion form ──────────────────────────────────────────────────────────────
document.getElementById('opinion-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var name = document.getElementById('op-name').value.trim();
  var text = document.getElementById('op-text').value.trim();
  var ok   = true;
  [['op-name', !name], ['op-text', !text]].forEach(function(pair) {
    document.getElementById(pair[0]).classList.toggle('form-input-error', pair[1]);
    if (pair[1]) ok = false;
  });
  if (!ok) return;

  if (EPOCH_API_URL && !EPOCH_API_URL.includes('PASTE')) {
    fetch(EPOCH_API_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({ type: 'opinion', name: name, text: text })
    }).catch(function() {});
  }

  // Optimistic prepend
  _allOpinions.unshift({ name: name, text: text, ts: Date.now() });
  renderOpinionsPreview();
  document.getElementById('op-success').style.display = 'block';
  document.getElementById('opinion-form').reset();
});

// ── Newsletter ────────────────────────────────────────────────────────────────
document.getElementById('newsletter-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var input = document.getElementById('nl-email');
  var email = input.value.trim();
  if (!isValidEmail(email)) { input.classList.add('form-input-error'); return; }
  input.classList.remove('form-input-error');

  if (typeof FORMSPREE_URL !== 'undefined' && FORMSPREE_URL && !FORMSPREE_URL.includes('PASTE')) {
    fetch(FORMSPREE_URL, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, _subject: 'Newsletter Signup' })
    }).catch(function() {});
  }

  document.getElementById('newsletter-form').style.display = 'none';
  document.getElementById('nl-success').style.display = 'block';
});
document.getElementById('nl-email').addEventListener('input', function() {
  this.classList.remove('form-input-error');
});

// ── Init ──────────────────────────────────────────────────────────────────────
initNav('community');
</script>

