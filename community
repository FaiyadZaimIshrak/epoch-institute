<style>
/* ── Section management ── */
.comm-section { display: none; min-height: 100vh; }
.comm-section.active { display: block; }
@keyframes sectionSlideIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.section-enter { animation: sectionSlideIn 0.4s cubic-bezier(0.22,1,0.36,1) forwards; }

/* ── Community page layout ── */
#community-page { padding-top: 100px; }
.community-section { padding: 40px 40px 0; max-width: 1100px; margin: 0 auto; }
.community-section-hd { margin-bottom: 28px; }
.community-section-title {
  font-family: 'Cinzel', serif; font-size: clamp(14px, 2vw, 19px);
  letter-spacing: 0.06em; color: var(--gold-light); margin: 0 0 8px;
}
.community-section-sub {
  font-family: 'Crimson Pro', Georgia, serif; font-size: 15px;
  color: var(--muted); line-height: 1.65; margin: 0; max-width: 600px;
}
.community-share-band {
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px; flex-wrap: wrap;
  background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, transparent 100%);
  border-top: 0.5px solid var(--border); border-bottom: 0.5px solid var(--border);
  padding: 40px; margin: 40px 0 0; max-width: none;
}

/* ── Blog grid ── */
.blog-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;
}
.blog-card {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 6px; padding: 24px 20px; cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  display: flex; flex-direction: column; gap: 8px;
  animation: cardFadeIn 0.35s cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes cardFadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
.blog-card:hover { border-color: var(--gold); background: rgba(201,168,76,0.04); }
.blog-card-tag {
  font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--gold); opacity: 0.8;
}
.blog-card-title {
  font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 0.04em;
  color: var(--gold-light); margin: 0; line-height: 1.5;
}
.blog-card-excerpt {
  font-family: 'Crimson Pro', Georgia, serif; font-size: 14px;
  color: var(--muted); opacity: 0.75; line-height: 1.6; margin: 0;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.blog-card-meta {
  font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.08em;
  color: var(--muted); opacity: 0.6; margin-top: auto;
}
.blog-loading, .opinions-loading {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.12em;
  color: var(--muted); opacity: 0.5; padding: 24px 0; text-align: center;
}
.blog-empty, .opinions-empty {
  font-family: 'Crimson Pro', Georgia, serif; font-size: 15px;
  color: var(--muted); opacity: 0.6; text-align: center; padding: 16px 0;
}
.blog-see-more {
  display: block; margin: 16px auto 0;
  font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--gold);
  background: none; border: 1px solid var(--border);
  padding: 10px 28px; cursor: pointer; transition: border-color 0.2s, color 0.2s;
}
.blog-see-more:hover { border-color: var(--gold); }

/* ── Opinions list ── */
.opinion-item {
  border-bottom: 1px solid var(--border); padding: 20px 0;
  display: flex; flex-direction: column; gap: 8px;
  animation: cardFadeIn 0.35s cubic-bezier(0.22,1,0.36,1) both;
}
.opinion-item:last-child { border-bottom: none; }
.opinion-item-name {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--gold); opacity: 0.85;
}
.opinion-item-text {
  font-family: 'Crimson Pro', Georgia, serif; font-size: 16px;
  color: var(--text); line-height: 1.7; font-style: italic;
}
.opinion-item-date {
  font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.08em;
  color: var(--muted); opacity: 0.6;
}

/* ── Newsletter ── */
.newsletter-form { display: flex; gap: 8px; align-items: flex-start; flex-wrap: wrap; }
.newsletter-form .form-input { flex: 1; min-width: 180px; }

/* ── Sub-section pages ── */
.community-page-inner { max-width: 860px; margin: 0 auto; padding: 0 40px 48px; }
.opinions-pagination {
  display: flex; justify-content: center; gap: 8px;
  padding: 24px 0 40px; flex-wrap: wrap;
}
.pagination-btn {
  font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.1em;
  padding: 8px 16px; border: 1px solid var(--border);
  background: none; color: var(--muted); cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.pagination-btn:hover { border-color: var(--gold); color: var(--gold); }
.pagination-btn.active { border-color: var(--gold); color: var(--gold); }

/* ── Drop zone ── */
.drop-zone {
  border: 1px dashed var(--border); border-radius: 6px;
  padding: 32px 24px; text-align: center; cursor: pointer;
  transition: border-color 0.2s, background 0.2s; margin-bottom: 16px;
}
.drop-zone.dragover { border-color: var(--gold); background: rgba(201,168,76,0.06); }
.drop-zone-label {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted);
}
.drop-zone-sub {
  font-family: 'Crimson Pro', Georgia, serif; font-size: 13px;
  color: var(--muted); opacity: 0.6; margin-top: 6px;
}
.drop-zone-file {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.06em;
  color: var(--gold); margin-top: 8px;
}

/* ── Article detail ── */
#article-detail .profile-detail-inner { padding-top: 40px; }

/* ── Share modal ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.75);
  display: none; align-items: center; justify-content: center;
  z-index: 9000; backdrop-filter: blur(4px); padding: 16px;
}
.modal-overlay.is-open { display: flex; }
.modal-box {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 8px; padding: 40px; max-width: 600px; width: 100%;
  max-height: 90vh; overflow-y: auto; position: relative;
}
.modal-close {
  position: absolute; top: 16px; right: 20px;
  background: none; border: none; cursor: pointer;
  font-size: 18px; color: var(--muted); transition: color 0.2s;
}
.modal-close:hover { color: var(--gold); }
.modal-title {
  font-family: 'Cinzel', serif; font-size: 16px; letter-spacing: 0.08em;
  color: var(--gold-light); margin: 0 0 28px;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .community-section { padding: 32px 16px 0; }
  .community-share-band { flex-direction: column; padding: 32px 16px; }
  .community-page-inner { padding: 0 16px 32px; }
  .opinions-pagination { padding: 16px 0 28px; }
  .pagination-btn { font-size: 8px; padding: 7px 12px; }
}
@media (max-width: 480px) {
  .blog-grid { grid-template-columns: 1fr; }
  .newsletter-form { flex-direction: column; }
}
