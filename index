// ── Article modal (announcements) ─────────────────────────────────────────────
function openAnnouncementModal(fileId, name) {
  document.getElementById('article-modal-title').textContent = name;
  document.getElementById('article-modal-meta').textContent = 'Announcement';
  document.getElementById('article-modal-frame').src =
    'https://drive.google.com/file/d/' + fileId + '/preview';
  const overlay = document.getElementById('article-modal');
  overlay.classList.remove('closing');
  overlay.style.display = 'flex';
  overlay.offsetHeight;
  overlay.classList.add('is-open');
  document.body.style.overflow = 'hidden';
}

(function() {
  const close = document.getElementById('article-modal-close');
  const overlay = document.getElementById('article-modal');
  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.classList.add('closing');
    setTimeout(() => {
      overlay.style.display = 'none';
      overlay.classList.remove('closing');
      document.body.style.overflow = '';
      document.getElementById('article-modal-frame').src = '';
    }, 220);
  }
  close.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
})();

// ── Announcements ─────────────────────────────────────────────────────────────
function loadAnnouncements() {
  if (!EPOCH_API_URL || EPOCH_API_URL.includes('PASTE')) {
    document.getElementById('announcements').style.display = 'none';
    return;
  }
  fetch(EPOCH_API_URL + '?action=announcements&callback=_')
    .then(r => r.text())
    .then(text => {
      const items = JSON.parse(text.replace(/^_\(/, '').replace(/\)[\s]*$/, ''));
      renderAnnouncements(Array.isArray(items) ? items : []);
    })
    .catch(() => renderAnnouncements([]));
}

function renderAnnouncements(items) {
  const section = document.getElementById('announcements');
  const grid    = document.getElementById('announcements-grid');
  const empty   = document.getElementById('announcements-empty');

  if (!items.length) {
    section.style.display = 'none';
    return;
  }

  section.style.display = '';
  empty.style.display = 'none';
  grid.innerHTML = items.map(item => {
    const isImg = /\.(png|jpe?g|gif|webp)$/i.test(item.name) || /^image\//.test(item.mimeType);
    const typeLabel = isImg ? 'Image Notice' : 'Document Notice';
    const imgHtml = isImg
      ? `<img class="announcement-card-img" src="https://lh3.googleusercontent.com/d/${item.id}" alt="${escHtml(item.name)}" loading="lazy">`
      : `<div class="announcement-card-img" style="display:flex;align-items:center;justify-content:center;font-size:40px;color:var(--gold);opacity:0.35;">📄</div>`;
    return `<div class="announcement-card" onclick="openAnnouncementModal('${item.id}','${escHtml(item.name).replace(/'/g,"\\'")}')">
      ${imgHtml}
      <div class="announcement-card-body">
        <span class="announcement-card-type">${typeLabel}</span>
        <span class="announcement-card-name">${escHtml(item.name.replace(/\.[^.]+$/, ''))}</span>
        <span class="announcement-card-cta">View →</span>
      </div>
    </div>`;
  }).join('');
}

loadAnnouncements();
setInterval(loadAnnouncements, 5 * 60 * 1000);
document.addEventListener('visibilitychange', () => {
  if (!document.hidden) loadAnnouncements();
});

// ── Today in History ──────────────────────────────────────────────────────────
(function() {
  const keys = Object.keys(TODAY_IN_HISTORY);

  function dayOfYear(mm, dd) {
    const months = [0,31,28,31,30,31,30,31,31,30,31,30,31];
    let d = dd;
    for (let i = 1; i < mm; i++) d += months[i];
    return d;
  }

  const now      = new Date();
  const todayMM  = String(now.getMonth() + 1).padStart(2, '0');
  const todayDD  = String(now.getDate()).padStart(2, '0');
  const todayKey = todayMM + '-' + todayDD;
  const todayDoy = dayOfYear(+todayMM, +todayDD);

  let entry = null, matchKey = null, exact = false;

  if (TODAY_IN_HISTORY[todayKey]) {
    entry = TODAY_IN_HISTORY[todayKey];
    matchKey = todayKey;
    exact = true;
  } else {
    let best = Infinity;
    keys.forEach(k => {
      const [mm, dd] = k.split('-').map(Number);
      let dist = Math.abs(dayOfYear(mm, dd) - todayDoy);
      dist = Math.min(dist, 365 - dist);
      if (dist < best && dist <= 15) { best = dist; matchKey = k; }
    });
    if (matchKey) entry = TODAY_IN_HISTORY[matchKey];
  }

  if (!entry) return;

  const regionNames = {
    EU: 'Europe', AS: 'Asia', AM: 'Americas', AF: 'Africa',
    ME: 'Middle East', BD: 'Bangladesh', GL: 'Global'
  };

  const card     = document.getElementById('tih-card');
  const dateEl   = document.getElementById('tih-date');
  const regionEl = document.getElementById('tih-region');
  const titleEl  = document.getElementById('tih-title');
  const yearEl   = document.getElementById('tih-year');
  const empireEl = document.getElementById('tih-empire-link');
  const shareEl  = document.getElementById('tih-share-link');

  const [emm, edd] = matchKey.split('-');
  const dispDate = new Date(2000, +emm - 1, +edd)
    .toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });

  if (!exact) {
    dateEl.textContent = 'On ' + dispDate + ' •';
    dateEl.style.opacity = '0.6';
  } else {
    dateEl.textContent = 'Today in History · ' + dispDate;
  }

  regionEl.textContent = regionNames[entry.region] || entry.region;
  titleEl.textContent  = entry.title;
  yearEl.textContent   = entry.year;

  if (entry.empire) {
    empireEl.style.display = '';
    empireEl.href = '/explorer.html#//' + encodeURIComponent(entry.empire);
  }

  const tweetText = encodeURIComponent(
    'On this day in history: ' + entry.title + ' (' + entry.year + ') via @EpochInstitute https://the-epoch-institute.org #history #epoch'
  );
  shareEl.href   = 'https://twitter.com/intent/tweet?text=' + tweetText;
  shareEl.target = '_blank';
  shareEl.rel    = 'noopener';

  card.style.display = '';
})();
</script>
