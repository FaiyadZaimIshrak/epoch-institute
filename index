// ── Article modal (announcements) ─────────────────────────────────────────────
function openAnnouncementModal(fileId, name) {
  document.getElementById('article-modal-title').textContent = name;
  document.getElementById('article-modal-meta').textContent = 'Announcement';
  document.getElementById('article-modal-frame').src =
    'https://drive.google.com/file/d/' + fileId + '/preview';
  const overlay = document.getElementById('article-modal');
  overlay.classList.remove('closing');
  overlay.style.display = 'flex';
  overlay.offsetHeight;
  overlay.classList.add('is-open');
  document.body.style.overflow = 'hidden';
  setTimeout(function() { var c = document.getElementById('article-modal-close'); if (c) c.focus(); }, 50);
}

(function() {
  const close = document.getElementById('article-modal-close');
  const overlay = document.getElementById('article-modal');
  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.classList.add('closing');
    setTimeout(() => {
      overlay.style.display = 'none';
      overlay.classList.remove('closing');
      document.body.style.overflow = '';
      document.getElementById('article-modal-frame').src = '';
    }, 220);
  }
  close.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.style.display !== 'none') closeModal();
  });
})();

// ── Announcements ─────────────────────────────────────────────────────────────
function loadAnnouncements() {
  if (!EPOCH_API_URL || EPOCH_API_URL.includes('PASTE')) {
    document.getElementById('announcements').style.display = 'none';
    return;
  }
  fetch(EPOCH_API_URL + '?action=announcements&callback=_')
    .then(r => r.text())
    .then(text => {
      const items = JSON.parse(text.replace(/^_\(/, '').replace(/\)[\s]*$/, ''));
      renderAnnouncements(Array.isArray(items) ? items : []);
    })
    .catch(() => renderAnnouncements([]));
}

function renderAnnouncements(items) {
  const section = document.getElementById('announcements');
  const grid    = document.getElementById('announcements-grid');
  const empty   = document.getElementById('announcements-empty');

  if (!items.length) {
    section.style.display = 'none';
    return;
  }

  section.style.display = '';
  empty.style.display = 'none';
  grid.innerHTML = items.map(item => {
    const isImg = /\.(png|jpe?g|gif|webp)$/i.test(item.name) || /^image\//.test(item.mimeType);
    const typeLabel = isImg ? 'Image Notice' : 'Document Notice';
    const imgHtml = isImg
      ? `<img class="announcement-card-img" src="https://lh3.googleusercontent.com/d/${item.id}" alt="${escHtml(item.name)}" loading="lazy">`
      : `<div class="announcement-card-img" style="display:flex;align-items:center;justify-content:center;font-size:40px;color:var(--gold);opacity:0.35;">📄</div>`;
    return `<div class="announcement-card" onclick="openAnnouncementModal('${item.id}','${escHtml(item.name).replace(/'/g,"\\'")}')">
      ${imgHtml}
      <div class="announcement-card-body">
        <span class="announcement-card-type">${typeLabel}</span>
        <span class="announcement-card-name">${escHtml(item.name.replace(/\.[^.]+$/, ''))}</span>
        <span class="announcement-card-cta">View →</span>
      </div>
    </div>`;
  }).join('');
}

loadAnnouncements();
setInterval(loadAnnouncements, 5 * 60 * 1000);
document.addEventListener('visibilitychange', () => {
  if (!document.hidden) loadAnnouncements();
});

// ── Today in History strip ────────────────────────────────────────────────────
(function() {
  var now     = new Date();
  var mm      = String(now.getMonth() + 1).padStart(2, '0');
  var dd      = String(now.getDate()).padStart(2, '0');
  var key     = mm + '-' + dd;
  var PAGE_URL = 'https://the-epoch-institute.org/today-in-history';

  var SHARE_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
  var GLOBE_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';

  var activeDropdown = null;

  function closeAllDropdowns() {
    if (activeDropdown) { activeDropdown.style.display = 'none'; activeDropdown = null; }
  }

  document.addEventListener('click', function(e) {
    if (activeDropdown && !activeDropdown.parentNode.contains(e.target)) closeAllDropdowns();
  });

  function buildCard(ev, ddId) {
    return '<div class="tih-card tih-strip-card">' +
      '<button class="tih-share-btn" data-dd="' + ddId + '" aria-label="Share this event">' + SHARE_SVG + '</button>' +
      '<div class="tih-share-dropdown" id="' + ddId + '" style="display:none;">' +
        '<button class="tih-share-dd-item" data-action="tweet" data-dd="' + ddId + '">Post on X</button>' +
        '<button class="tih-share-dd-item" data-action="copy" data-dd="' + ddId + '">Copy link</button>' +
      '</div>' +
      '<p class="tih-year">' + escHtml(ev.yearDisplay || String(ev.year)) + '</p>' +
      '<p class="tih-title">' + escHtml(ev.title) + '</p>' +
      '<p class="tih-desc">' + escHtml(ev.description) + '</p>' +
    '</div>';
  }

  function buildPinnedCard(day) {
    return '<div class="tih-card tih-strip-card tih-pinned-card tih-strip-pinned">' +
      '<span class="tih-pinned-icon">' + GLOBE_SVG + '</span>' +
      '<p class="tih-pinned-label">Today\'s International Day</p>' +
      '<p class="tih-pinned-title">' + escHtml(day.name) + '</p>' +
      '<p class="tih-pinned-desc">' + escHtml(day.description) + '</p>' +
    '</div>';
  }

  function renderStrip(events, intlDay) {
    if (!events.length && !intlDay) return;
    var strip   = document.getElementById('tih-strip');
    var dateEl  = document.getElementById('tih-strip-date');
    var cardsEl = document.getElementById('tih-strip-cards');

    var dow      = now.toLocaleDateString('en-GB', { weekday: 'long' });
    var fullDate = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    dateEl.innerHTML =
      '<span class="tih-date-sep"></span>' +
      '<span class="tih-date-dow">' + escHtml(dow) + '</span>' +
      '<span class="tih-date-full">' + escHtml(fullDate) + '</span>' +
      '<span class="tih-date-sep"></span>';

    var count    = intlDay ? 2 : 3;
    var pool     = events.slice().sort(function() { return Math.random() - 0.5; });
    var selected = pool.slice(0, Math.min(count, pool.length));

    var html = '';
    if (intlDay) html += buildPinnedCard(intlDay);
    var evMap = {};
    selected.forEach(function(ev, i) {
      var ddId = 'strip-dd-' + i;
      html += buildCard(ev, ddId);
      evMap[ddId] = ev;
    });
    cardsEl.innerHTML = html;

    cardsEl.querySelectorAll('.tih-share-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var ddId = btn.dataset.dd;
        var ev   = evMap[ddId];
        if (navigator.share) {
          navigator.share({ title: ev.title, text: composeTweet(ev), url: PAGE_URL }).catch(function() {});
          return;
        }
        var dd = document.getElementById(ddId);
        if (dd.style.display === 'none') {
          closeAllDropdowns();
          dd.style.display = '';
          activeDropdown = dd;
        } else {
          closeAllDropdowns();
        }
      });
    });

    cardsEl.querySelectorAll('.tih-share-dd-item').forEach(function(item) {
      item.addEventListener('click', function(e) {
        e.stopPropagation();
        var ddId   = item.dataset.dd;
        var ev     = evMap[ddId];
        var action = item.dataset.action;
        if (action === 'tweet') {
          window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(composeTweet(ev)), '_blank');
          closeAllDropdowns();
        } else if (action === 'copy') {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(PAGE_URL).then(function() {
              var orig = item.textContent;
              item.textContent = '✓ Copied!';
              setTimeout(function() { item.textContent = orig; }, 2000);
            }).catch(function() {});
          }
          setTimeout(closeAllDropdowns, 2100);
        }
      });
    });

    strip.style.display = '';
  }

  // Show skeleton cards while loading
  (function() {
    var strip = document.getElementById('tih-strip');
    var cardsEl = document.getElementById('tih-strip-cards');
    var skelHtml = '';
    for (var i = 0; i < 2; i++) skelHtml += '<div class="tih-skeleton-card tih-strip-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div>';
    cardsEl.innerHTML = skelHtml;
    strip.style.display = '';
    var dateEl = document.getElementById('tih-strip-date');
    var dowLabel = now.toLocaleDateString('en-GB', { weekday: 'long' });
    var fullDate = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    dateEl.innerHTML = '<span class="tih-date-sep"></span><span class="tih-date-dow">' + escHtml(dowLabel) + '</span><span class="tih-date-full">' + escHtml(fullDate) + '</span><span class="tih-date-sep"></span>';
  })();

  Promise.all([
    fetch('/data/history.json').then(function(r) { if (!r.ok) throw new Error(); return r.json(); }),
    fetch('/data/international-days.json').then(function(r) { return r.ok ? r.json() : {}; }).catch(function() { return {}; })
  ]).then(function(results) {
    var events  = results[0][key] || [];
    var intlDay = results[1][key] || null;
    renderStrip(events, intlDay);
  }).catch(function() {
    document.getElementById('tih-strip').style.display = 'none';
  });
})();
</script>

<script>
// ── Newsletter form ──────────────────────────────────────────────────────────
(function() {
  var form = document.getElementById('newsletter-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var email = document.getElementById('newsletter-email').value.trim();
    if (!isValidEmail(email)) return;
    var btn = form.querySelector('button');
    btn.disabled = true; btn.textContent = 'Subscribing…';
    fetch(FORMSPREE_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ email: email, _subject: 'Newsletter signup', source: 'homepage' })
    }).then(function() {
      var msg = document.getElementById('newsletter-msg');
      msg.textContent = "You're subscribed.";
      msg.style.display = 'block';
      form.style.display = 'none';
    }).catch(function() {
      btn.disabled = false; btn.textContent = 'Subscribe';
    });
  });
})();

// ── Explorer teaser — animated Classical-era timeline bars ───────────────────
(function() {
  var chartEl = document.getElementById('explorer-teaser-chart');
  if (!chartEl) return;

  var S = -500, E = 500, RANGE = 1000;
  function pct(y) { return (Math.max(S, Math.min(E, y)) - S) / RANGE * 100; }

  // Data from shared-data.js EMPIRES (points[0][0]=start, points[-1][0]=end)
  var BARS = [
    { name: 'Carthage',          s: -814, e: -146, top: 18,  cls: 'tl-above', op: 0.45 },
    { name: 'Seleucid Empire',   s: -312, e:  -63, top: 46,  cls: 'tl-above', op: 0.45 },
    { name: 'Ptolemaic Egypt',   s: -323, e:  -30, top: 74,  cls: 'tl-above', op: 0.50 },
    { name: 'Macedonian Empire', s: -336, e: -323, top: 102, cls: 'tl-above', op: 0.65 },
    { name: 'Parthian Empire',   s: -247, e:  224, top: 152, cls: 'tl-below', op: 0.50 },
    { name: 'Han Dynasty',       s: -206, e:  220, top: 180, cls: 'tl-below', op: 0.60 },
    { name: 'Roman Empire',      s:  -27, e:  476, top: 208, cls: 'tl-below', op: 0.65 },
  ];

  var MARKERS = [
    { y: -500, label: '500 BCE' },
    { y: -250, label: '250 BCE' },
    { y:    0, label: '0' },
    { y:  250, label: '250 CE' },
    { y:  500, label: '500 CE' },
  ];

  var html = '<div class="tl-axis"></div>';
  MARKERS.forEach(function(m) {
    html += '<div class="tl-mark" style="left:' + pct(m.y).toFixed(1) + '%">' +
      '<div class="tl-mark-tick"></div><span class="tl-mark-label">' + m.label + '</span></div>';
  });
  BARS.forEach(function(b, i) {
    var l = pct(b.s), w = Math.max(1.5, pct(b.e) - l);
    html += '<div class="tl-bar ' + b.cls + '" data-idx="' + i + '" data-op="' + b.op + '" ' +
      'style="top:' + b.top + 'px;left:' + l.toFixed(1) + '%;width:' + w.toFixed(1) + '%;opacity:0;transform:translateY(10px);">' +
      '<span class="tl-bar-label">' + b.name + '</span></div>';
  });
  chartEl.innerHTML = html;

  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var barEls = Array.prototype.slice.call(chartEl.querySelectorAll('.tl-bar'));
  var loopTimer = null, outTimer = null;

  function animate() {
    clearTimeout(outTimer);
    barEls.forEach(function(b) {
      b.style.transition = 'none';
      b.style.opacity = '0';
      b.style.transform = 'translateY(10px)';
    });
    if (reduced) {
      barEls.forEach(function(b) { b.style.opacity = b.dataset.op; b.style.transform = 'translateY(0)'; });
      return;
    }
    barEls.forEach(function(b, i) {
      setTimeout(function() {
        b.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        b.style.opacity = b.dataset.op;
        b.style.transform = 'translateY(0)';
      }, i * 200 + 50);
    });
    var fadeStart = barEls.length * 200 + 650 + 4000;
    outTimer = setTimeout(function() {
      barEls.forEach(function(b) {
        b.style.transition = 'opacity 0.8s ease';
        b.style.opacity = '0';
      });
    }, fadeStart);
  }

  var running = false;
  function start() {
    if (running) return;
    running = true;
    animate();
    loopTimer = setInterval(animate, 12000);
  }
  function stop() {
    running = false;
    clearInterval(loopTimer);
    clearTimeout(outTimer);
    loopTimer = null;
  }

  if (window.IntersectionObserver) {
    var io = new IntersectionObserver(function(entries) {
      entries[0].isIntersecting ? start() : stop();
    }, { threshold: 0.1 });
    io.observe(chartEl);
  } else {
    start();
  }
})();
</script>
