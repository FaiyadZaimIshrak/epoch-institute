// ── Article modal (announcements) ─────────────────────────────────────────────
function openAnnouncementModal(fileId, name) {
  document.getElementById('article-modal-title').textContent = name;
  document.getElementById('article-modal-meta').textContent = 'Announcement';
  document.getElementById('article-modal-frame').src =
    'https://drive.google.com/file/d/' + fileId + '/preview';
  const overlay = document.getElementById('article-modal');
  overlay.classList.remove('closing');
  overlay.style.display = 'flex';
  overlay.offsetHeight;
  overlay.classList.add('is-open');
  document.body.style.overflow = 'hidden';
}

(function() {
  const close = document.getElementById('article-modal-close');
  const overlay = document.getElementById('article-modal');
  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.classList.add('closing');
    setTimeout(() => {
      overlay.style.display = 'none';
      overlay.classList.remove('closing');
      document.body.style.overflow = '';
      document.getElementById('article-modal-frame').src = '';
    }, 220);
  }
  close.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
})();

// ── Announcements ─────────────────────────────────────────────────────────────
function loadAnnouncements() {
  if (!EPOCH_API_URL || EPOCH_API_URL.includes('PASTE')) {
    document.getElementById('announcements').style.display = 'none';
    return;
  }
  fetch(EPOCH_API_URL + '?action=announcements&callback=_')
    .then(r => r.text())
    .then(text => {
      const items = JSON.parse(text.replace(/^_\(/, '').replace(/\)[\s]*$/, ''));
      renderAnnouncements(Array.isArray(items) ? items : []);
    })
    .catch(() => renderAnnouncements([]));
}

function renderAnnouncements(items) {
  const section = document.getElementById('announcements');
  const grid    = document.getElementById('announcements-grid');
  const empty   = document.getElementById('announcements-empty');

  if (!items.length) {
    section.style.display = 'none';
    return;
  }

  section.style.display = '';
  empty.style.display = 'none';
  grid.innerHTML = items.map(item => {
    const isImg = /\.(png|jpe?g|gif|webp)$/i.test(item.name) || /^image\//.test(item.mimeType);
    const typeLabel = isImg ? 'Image Notice' : 'Document Notice';
    const imgHtml = isImg
      ? `<img class="announcement-card-img" src="https://lh3.googleusercontent.com/d/${item.id}" alt="${escHtml(item.name)}" loading="lazy">`
      : `<div class="announcement-card-img" style="display:flex;align-items:center;justify-content:center;font-size:40px;color:var(--gold);opacity:0.35;">📄</div>`;
    return `<div class="announcement-card" onclick="openAnnouncementModal('${item.id}','${escHtml(item.name).replace(/'/g,"\\'")}')">
      ${imgHtml}
      <div class="announcement-card-body">
        <span class="announcement-card-type">${typeLabel}</span>
        <span class="announcement-card-name">${escHtml(item.name.replace(/\.[^.]+$/, ''))}</span>
        <span class="announcement-card-cta">View →</span>
      </div>
    </div>`;
  }).join('');
}

loadAnnouncements();
setInterval(loadAnnouncements, 5 * 60 * 1000);
document.addEventListener('visibilitychange', () => {
  if (!document.hidden) loadAnnouncements();
});

// ── Today in History strip ────────────────────────────────────────────────────
(function() {
  var now  = new Date();
  var mm   = String(now.getMonth() + 1).padStart(2, '0');
  var dd   = String(now.getDate()).padStart(2, '0');
  var key  = mm + '-' + dd;
  var date = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });

  function renderStrip(events) {
    if (!events || !events.length) return;
    var strip   = document.getElementById('tih-strip');
    var dateEl  = document.getElementById('tih-strip-date');
    var cardsEl = document.getElementById('tih-strip-cards');

    dateEl.textContent = 'Today in History · ' + date;

    // Pick up to 3 random events
    var pool     = events.slice().sort(function() { return Math.random() - 0.5; });
    var selected = pool.slice(0, Math.min(3, pool.length));

    cardsEl.innerHTML = selected.map(function(ev) {
      return '<div class="tih-card tih-strip-card">' +
        '<p class="tih-year">' + escHtml(ev.yearDisplay || String(ev.year)) + '</p>' +
        '<p class="tih-title">' + escHtml(ev.title) + '</p>' +
        '<p class="tih-desc">' + escHtml(ev.description) + '</p>' +
      '</div>';
    }).join('');

    strip.style.display = '';
  }

  fetch('/data/history.json')
    .then(function(r) {
      if (!r.ok) throw new Error('not found');
      return r.json();
    })
    .then(function(data) { renderStrip(data[key] || []); })
    .catch(function() {
      // Fallback to TODAY_IN_HISTORY (single-entry, available in shared-data.js)
      var entry = (typeof TODAY_IN_HISTORY !== 'undefined') && TODAY_IN_HISTORY[key];
      if (entry) {
        renderStrip([{
          year: null, yearDisplay: entry.year,
          title: entry.title,
          description: ''
        }]);
      }
    });
})();
</script>
