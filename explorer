<script>
initNav('explorer');

// ── Google Drive config for empire emblems ─────────────────────────────────
const GDRIVE_FOLDER_ID = "1ZCKyZSlOkpv5BYHiDZVsOShv1B5aG5Xg";
const GDRIVE_API_KEY   = "AIzaSyBR5wx7et8NPsxA51vuR4zxlQlSlU9-a2A";

let _driveFolderPromise = null;
function loadDriveFolder() {
  if (_driveFolderPromise) return _driveFolderPromise;
  _driveFolderPromise = (async () => {
    const map = {};
    if (!GDRIVE_FOLDER_ID || GDRIVE_FOLDER_ID === "PASTE_FOLDER_ID_HERE") return map;
    let pageToken = "";
    do {
      const params = new URLSearchParams({
        q: `'${GDRIVE_FOLDER_ID}' in parents`,
        fields: "nextPageToken,files(id,name,thumbnailLink)",
        pageSize: "1000",
        key: GDRIVE_API_KEY
      });
      if (pageToken) params.set("pageToken", pageToken);
      try {
        const r = await fetch(`https://www.googleapis.com/drive/v3/files?${params}`);
        const d = await r.json();
        if (d.files) {
          for (const f of d.files) {
            const key = f.name.replace(/\.[^/.]+$/, "").trim().toLowerCase();
            map[key] = { id: f.id, thumb: f.thumbnailLink || null };
          }
        }
        pageToken = d.nextPageToken || "";
      } catch(e) { pageToken = ""; }
    } while (pageToken);
    return map;
  })();
  return _driveFolderPromise;
}

const emblemCache = {};
async function fetchEmblem(empName) {
  if (empName in emblemCache) return emblemCache[empName];
  let url = null;
  try {
    const driveMap = await loadDriveFolder();
    const key = empName.trim().toLowerCase();
    if (driveMap[key]) {
      url = driveMap[key].thumb || `https://drive.google.com/uc?export=view&id=${driveMap[key].id}`;
    }
  } catch(e) {}
  emblemCache[empName] = url || false;
  return url || false;
}

// ── State ──────────────────────────────────────────────────────────────────
let _lastEventWasTouch = false;
document.addEventListener("touchstart", () => { _lastEventWasTouch = true; }, { passive: true });
document.addEventListener("mousedown",  () => { _lastEventWasTouch = false; }, { passive: true });

let activeRegion = null;
let soloEmpire = null;
let compareEmpire = null;
let showLabels = false;
let showEvents = false;
let xRange = null;
let viewDomain = null;
let searchTerm = "";
let playYear = null;
let playTimer = null;
let isPlaying = false;

// ── Layout ─────────────────────────────────────────────────────────────────
const margin = { top: 20, right: 24, bottom: 48, left: 44 };
let W, H, innerW, innerH;

const container = document.getElementById("chart");
const svg = d3.select("#chart").append("svg");
const g = svg.append("g").attr("transform", `translate(${margin.left},${margin.top})`);

const defs = svg.append("defs");
defs.append("clipPath").attr("id","chart-clip")
  .append("rect").attr("x",0).attr("y",0);

const xAxisG = g.append("g").attr("class","axis x-axis");
const yAxisG = g.append("g").attr("class","axis y-axis");
const gridG = g.append("g").attr("class","grid");
const eraBandsG = g.append("g").attr("class","era-bands");
const areaG = g.append("g").attr("class","areas");
const linesG = g.append("g").attr("class","lines").attr("clip-path","url(#chart-clip)");
const dotsG = g.append("g").attr("class","dots").attr("clip-path","url(#chart-clip)");
const labelsG = g.append("g").attr("class","empire-labels");
const peaksG = g.append("g").attr("class","peaks");
const crosshairG = g.append("g").attr("class","crosshair-group");

const xScale = d3.scaleLinear();
const yScale = d3.scaleLinear().domain([0, 10]);

const lineGen = d3.line()
  .x(d => xScale(d[0]))
  .y(d => yScale(d[1]))
  .curve(d3.curveCatmullRom.alpha(0.5));

const areaGen = d3.area()
  .x(d => xScale(d[0]))
  .y0(d => yScale(0))
  .y1(d => yScale(d[1]))
  .curve(d3.curveCatmullRom.alpha(0.5));

const tooltip = document.getElementById("tooltip");

// ── Helper functions ───────────────────────────────────────────────────────
function formatYear(y) {
  if (y < 0) return `${Math.abs(Math.round(y))} BCE`;
  return `${Math.round(y)} CE`;
}

function getEffectiveDomain() {
  return viewDomain || xRange || ERAS.all;
}

function isVisible(empire) {
  if (activeRegion !== null && activeRegion !== "All" && empire.region !== activeRegion) return false;
  const [x0, x1] = getEffectiveDomain();
  return empire.points.some(p => p[0] >= x0 && p[0] <= x1);
}

function getPointsInRange(empire) {
  const effectivePts = (playYear !== null)
    ? empire.points.filter(p => p[0] <= playYear)
    : empire.points;
  if (!effectivePts.length) return [];
  if (soloEmpire === empire.name) return effectivePts;
  const [x0, x1] = getEffectiveDomain();
  return effectivePts.filter((p, i, arr) => {
    const inRange = p[0] >= x0 && p[0] <= x1;
    const prevIn = i > 0 && arr[i-1][0] >= x0 && arr[i-1][0] <= x1;
    const nextIn = i < arr.length-1 && arr[i+1][0] >= x0 && arr[i+1][0] <= x1;
    return inRange || prevIn || nextIn;
  });
}

function getLineOpacity(d) {
  if (soloEmpire) {
    if (d.name === soloEmpire || d.name === compareEmpire) return 1;
    return 0.04;
  }
  if (searchTerm) return d.name.toLowerCase().includes(searchTerm) ? 0.95 : 0.06;
  return 0.75;
}

function positionTooltip(evTip, mx, my) {
  const panelOpen = document.getElementById("info-panel").classList.contains("open");
  const rightBound = panelOpen ? window.innerWidth - 310 : window.innerWidth - 10;
  const tipW = 280;
  const tx = (mx + 14 + tipW > rightBound) ? Math.max(0, mx - 14 - tipW) : mx + 14;
  evTip.style.left = tx + "px";
  evTip.style.top = Math.max(10, Math.min(my - 10, window.innerHeight - 300)) + "px";
}

// ── Playback ───────────────────────────────────────────────────────────────
function getPlayRange() {
  return xRange || ERAS.all;
}

function setPlayYear(yr) {
  playYear = yr;
  const [start, end] = getPlayRange();
  const pct = ((yr - start) / (end - start)) * 100;
  document.getElementById("play-scrubber").value = pct;
  document.getElementById("play-year").textContent = formatYear(yr);
  render();
}

function startPlay() {
  if (isPlaying) return;
  isPlaying = true;
  document.getElementById("play-btn").textContent = "⏸";
  const [start, end] = getPlayRange();
  if (playYear === null || playYear >= end) playYear = start;
  const totalMs = 12000;
  const range = end - start;
  let lastTime = null;
  playTimer = d3.timer(elapsed => {
    if (!isPlaying) { playTimer.stop(); return; }
    if (lastTime === null) lastTime = elapsed;
    const dt = elapsed - lastTime;
    lastTime = elapsed;
    playYear = Math.min(end, playYear + (range * dt / totalMs));
    setPlayYear(playYear);
    if (playYear >= end) stopPlay();
  });
}

function stopPlay() {
  isPlaying = false;
  if (playTimer) { playTimer.stop(); playTimer = null; }
  document.getElementById("play-btn").textContent = "▶";
}

// ── Minimap ────────────────────────────────────────────────────────────────
const mmMargin = {top:4, right:24, bottom:16, left:44};
const mmH = 48;
let mmSvg, mmX, mmBrush, mmBrushG;

function buildMinimap() {
  const wrapper = document.getElementById("minimap");
  wrapper.innerHTML = "";
  const W2 = wrapper.clientWidth || container.clientWidth;
  const mmInnerW = W2 - mmMargin.left - mmMargin.right;
  const mmInnerH = mmH - mmMargin.top - mmMargin.bottom;

  mmSvg = d3.select("#minimap").append("svg").attr("width", W2).attr("height", mmH);
  const mmG = mmSvg.append("g").attr("transform",`translate(${mmMargin.left},${mmMargin.top})`);

  mmX = d3.scaleLinear().domain(ERAS.all).range([0, mmInnerW]);
  const mmY = d3.scaleLinear().domain([0,10]).range([mmInnerH, 0]);
  const mmLine = d3.line().x(d=>mmX(d[0])).y(d=>mmY(d[1])).curve(d3.curveCatmullRom.alpha(0.5));

  const filtered = activeRegion && activeRegion !== "All"
    ? EMPIRES.filter(e => e.region === activeRegion)
    : EMPIRES;

  filtered.forEach(emp => {
    mmG.append("path").datum(emp.points)
      .attr("fill","none").attr("stroke",emp.color)
      .attr("stroke-width",0.5).attr("opacity",0.3)
      .attr("d", mmLine);
  });

  mmG.append("g").attr("transform",`translate(0,${mmInnerH})`).call(
    d3.axisBottom(mmX).ticks(8).tickFormat(y => { const v=Math.round(y); return v<0?`${Math.abs(v)}B`:`${v}`; }).tickSize(3)
  ).selectAll("text").attr("fill","var(--muted)").attr("font-size","8px");
  mmG.select(".domain").attr("stroke","var(--border)");

  mmBrush = d3.brushX()
    .extent([[0,0],[mmInnerW, mmInnerH]])
    .on("brush end", ({selection, sourceEvent}) => {
      if (!sourceEvent) return;
      if (!selection) return;
      const [x0, x1] = selection.map(mmX.invert);
      xRange = [x0, x1];
      viewDomain = null;
      soloEmpire = null;
      compareEmpire = null;
      stopPlay();
      playYear = null;
      updateZoomButton();
      document.getElementById("era-select").value = "";
      render();
      encodeState();
    });

  mmBrushG = mmG.append("g").attr("class","brush").call(mmBrush);
  mmBrushG.select(".selection")
    .attr("fill","var(--gold)").attr("fill-opacity",0.15)
    .attr("stroke","var(--gold)").attr("stroke-width",1);

  updateMinimapBrush();
}

function updateMinimapBrush() {
  if (!mmBrush || !mmBrushG || !xRange) return;
  const [x0,x1] = xRange;
  if (!mmX) return;
  mmBrushG.call(mmBrush.move, [mmX(x0), mmX(x1)]);
}

// ── URL State ──────────────────────────────────────────────────────────────
function encodeState() {
  const era = Object.entries(ERAS).find(([k,v]) => xRange && v[0]===xRange[0] && v[1]===xRange[1]);
  const parts = [
    activeRegion || "",
    era ? era[0] : "",
    soloEmpire || ""
  ];
  history.replaceState(null, "", "#" + parts.map(encodeURIComponent).join("/"));
}

function decodeState() {
  const hash = location.hash.slice(1);
  if (!hash) return;
  const [region, era, empire] = hash.split("/").map(decodeURIComponent);
  if (region) {
    activeRegion = region;
    document.querySelectorAll(".tab").forEach(t => {
      t.classList.toggle("active", t.dataset.region === region);
    });
  }
  if (era && ERAS[era]) {
    xRange = ERAS[era];
    document.getElementById("era-select").value = era;
  }
  if (empire) {
    soloEmpire = empire;
    const emp = EMPIRES.find(e => e.name === empire);
    if (emp) {
      const pts = emp.points;
      const pad = (pts[pts.length-1][0] - pts[0][0]) * 0.04;
      viewDomain = [pts[0][0] - pad, pts[pts.length-1][0] + pad];
    }
  }
}

// ── Info panel ─────────────────────────────────────────────────────────────
function updateInfoPanel() {
  const panel = document.getElementById("info-panel");
  const compareSection = document.getElementById("info-compare-section");
  const divider2 = document.getElementById("info-divider2");

  if (!soloEmpire) {
    panel.classList.remove("open");
    document.body.classList.remove("panel-open");
    compareSection.style.display = "none";
    divider2.style.display = "none";
    setTimeout(() => { resize(); buildMinimap(); }, 420);
    return;
  }

  const emp = EMPIRES.find(e => e.name === soloEmpire);
  if (!emp) return;
  const pts = emp.points;
  const peak = pts.reduce((a,b) => b[1]>a[1]?b:a);
  const duration = Math.round(pts[pts.length-1][0] - pts[0][0]);
  document.getElementById("info-region").textContent = emp.region;
  document.getElementById("info-name").textContent = emp.name;

  const emblemEl = document.getElementById("info-emblem");
  const emblemImg = document.getElementById("info-emblem-img");
  emblemEl.style.display = "none";
  fetchEmblem(emp.name).then(url => {
    if (url && document.getElementById("info-name").textContent === emp.name) {
      emblemImg.src = url;
      emblemImg.alt = emp.name;
      emblemEl.style.display = "flex";
    }
  });
  document.getElementById("info-peak").textContent = formatYear(peak[0]);
  document.getElementById("info-duration").textContent = `${Math.abs(duration)} years`;
  document.getElementById("info-summary").textContent = EMPIRE_INFO[emp.name] || "Historical data for this empire is being compiled.";

  // Update profile link
  document.getElementById("info-view-profile").href = "/empire/" + toSlug(emp.name);

  if (compareEmpire) {
    const emp2 = EMPIRES.find(e => e.name === compareEmpire);
    if (emp2) {
      const pts2 = emp2.points;
      const peak2 = pts2.reduce((a,b) => b[1]>a[1]?b:a);
      const duration2 = Math.round(pts2[pts2.length-1][0] - pts2[0][0]);
      document.getElementById("info-compare-region").textContent = emp2.region;
      document.getElementById("info-compare-name").textContent = emp2.name;
      document.getElementById("info-compare-peak").textContent = formatYear(peak2[0]);
      document.getElementById("info-compare-duration").textContent = `${Math.abs(duration2)} years`;
      document.getElementById("info-compare-summary").textContent = EMPIRE_INFO[emp2.name] || "Historical data for this empire is being compiled.";
      compareSection.style.display = "flex";
      divider2.style.display = "block";
    }
  } else {
    compareSection.style.display = "none";
    divider2.style.display = "none";
  }

  const wasOpen = panel.classList.contains("open");
  panel.classList.add("open");
  document.body.classList.add("panel-open");
  if (!wasOpen) setTimeout(() => { resize(); buildMinimap(); }, 420);
}

// ── Tooltips ───────────────────────────────────────────────────────────────
function showTooltip(event, d) {
  const [mx, my] = d3.pointer(event, document.body);
  const pts = getPointsInRange(d);
  const mouseX = xScale.invert(d3.pointer(event, g.node())[0]);
  const closest = pts.reduce((a,b) => Math.abs(b[0]-mouseX) < Math.abs(a[0]-mouseX) ? b : a);
  tooltip.innerHTML = `
    <div class="tip-empire">${d.name}</div>
    <div class="tip-region">${d.region}</div>
    <div class="tip-row"><span>Year</span><span class="tip-val">${formatYear(closest[0])}</span></div>
    <div class="tip-row"><span>Power Score</span><span class="tip-val">${closest[1].toFixed(1)}</span></div>
  `;
  tooltip.classList.add("visible");
  const tx = Math.min(mx + 14, window.innerWidth - 240);
  const ty = Math.min(my - 10, window.innerHeight - 120);
  tooltip.style.left = tx + "px";
  tooltip.style.top = ty + "px";
}
function hideTooltip() { tooltip.classList.remove("visible"); }

// ── Zoom ───────────────────────────────────────────────────────────────────
function zoomTo(targetDomain, duration) {
  viewDomain = targetDomain;
  const fromDomain = xScale.domain().slice();
  const tickCount = Math.max(4, Math.min(12, Math.round(innerW / 100)));
  const fmtTick = y => { const v = Math.round(y); return v < 0 ? `${Math.abs(v)}BCE` : `${v}CE`; };
  const t = d3.transition().duration(duration).ease(d3.easeCubicInOut);
  svg.transition(t).tween("xzoom", () => {
    const interp = d3.interpolate(fromDomain, targetDomain);
    return ti => {
      xScale.domain(interp(ti));
      xAxisG.attr("transform", `translate(0,${innerH})`)
        .call(d3.axisBottom(xScale).ticks(tickCount).tickFormat(fmtTick));
      linesG.selectAll(".empire-line").attr("d", d => lineGen(getPointsInRange(d)));
    };
  });
  t.on("end", () => { render(); updateZoomButton(); });
}

function updateZoomButton() {
  document.getElementById("zoom-reset-btn").classList.toggle("visible", soloEmpire !== null);
}

function zoomToCompare() {
  const e1 = EMPIRES.find(e => e.name === soloEmpire);
  const e2 = EMPIRES.find(e => e.name === compareEmpire);
  if (!e1 || !e2) return;
  const allPts = [...e1.points, ...e2.points];
  const minX = Math.min(...allPts.map(p => p[0]));
  const maxX = Math.max(...allPts.map(p => p[0]));
  const pad = (maxX - minX) * 0.04;
  zoomTo([minX - pad, maxX + pad], 650);
}

function toggleSolo(name) {
  const deselecting = soloEmpire === name;
  soloEmpire = deselecting ? null : name;
  if (deselecting) compareEmpire = null;
  if (soloEmpire) {
    const empire = EMPIRES.find(e => e.name === soloEmpire);
    const pts = empire.points;
    const minX = pts[0][0];
    const maxX = pts[pts.length - 1][0];
    const pad = (maxX - minX) * 0.04;
    zoomTo([minX - pad, maxX + pad], 750);
  } else {
    viewDomain = null;
    zoomTo(xRange || ERAS.all, 600);
  }
  updateLegendActive();
  updateZoomButton();
  updateInfoPanel();
  encodeState();
}

function updateLegendActive() {
  document.querySelectorAll(".legend-item").forEach(el => {
    el.classList.remove("solo-active");
    if (soloEmpire && el.dataset.name === soloEmpire) el.classList.add("solo-active");
  });
}

function updateLegend(visible) {
  const legend = document.getElementById("legend");
  legend.innerHTML = "";
  const grouped = {};
  visible.forEach(e => {
    if (!grouped[e.region]) grouped[e.region] = [];
    grouped[e.region].push(e);
  });
  Object.entries(grouped).forEach(([region, empires]) => {
    const div = document.createElement("div");
    div.className = "legend-region";
    div.innerHTML = `<div class="legend-region-title">${region}</div>`;
    empires.sort((a, b) => a.points[0][0] - b.points[0][0]);
    empires.forEach(empire => {
      const item = document.createElement("div");
      item.className = "legend-item" + (soloEmpire === empire.name ? " solo-active" : "");
      item.dataset.name = empire.name;
      item.title = "Click to isolate · Shift+click to compare";
      item.innerHTML = `<div class="legend-swatch" style="background:${empire.color}"></div>${empire.name}`;
      item.addEventListener("click", (event) => {
        if (event.shiftKey && soloEmpire && soloEmpire !== empire.name) {
          compareEmpire = compareEmpire === empire.name ? null : empire.name;
          if (compareEmpire) zoomToCompare();
          render();
          updateLegendActive();
          updateInfoPanel();
        } else {
          compareEmpire = null;
          toggleSolo(empire.name);
        }
      });
      div.appendChild(item);
    });
    legend.appendChild(div);
  });
}

// ── Resize ─────────────────────────────────────────────────────────────────
function resize() {
  W = container.clientWidth;
  H = Math.max(480, Math.min(600, window.innerHeight * 0.55));
  innerW = W - margin.left - margin.right;
  innerH = H - margin.top - margin.bottom;
  svg.attr("width", W).attr("height", H);
  xScale.range([0, innerW]);
  yScale.range([innerH, 0]);
  svg.select("#chart-clip rect").attr("width", innerW).attr("height", innerH + 10);
  render();
}

// ── Render ─────────────────────────────────────────────────────────────────
function render() {
  const guide = document.getElementById("chart-guide");
  if (activeRegion === null || xRange === null) {
    linesG.selectAll("*").remove();
    dotsG.selectAll("*").remove();
    labelsG.selectAll("*").remove();
    eraBandsG.selectAll("*").remove();
    areaG.selectAll("*").remove();
    peaksG.selectAll("*").remove();
    crosshairG.selectAll("*").remove();
    xAxisG.selectAll("*").remove();
    yAxisG.selectAll("*").remove();
    gridG.selectAll("*").remove();
    svg.selectAll(".axis-label-x,.axis-label-y").remove();
    guide.classList.add("visible");
    updateLegend([]);
    document.getElementById("playback-bar").style.display = "none";
    document.getElementById("minimap-wrapper").style.display = "none";
    return;
  }
  guide.classList.remove("visible");
  document.getElementById("playback-bar").style.display = (activeRegion && xRange) ? "flex" : "none";
  document.getElementById("minimap-wrapper").style.display = activeRegion ? "block" : "none";

  xScale.domain(getEffectiveDomain());
  yScale.domain([0, 10]);

  const tickCount = Math.max(4, Math.min(12, Math.round(innerW / 100)));
  xAxisG.attr("transform", `translate(0,${innerH})`).call(
    d3.axisBottom(xScale).ticks(tickCount).tickFormat(y => {
      const v = Math.round(y);
      if (v < 0) return `${Math.abs(v)}BCE`;
      return `${v}CE`;
    })
  );
  yAxisG.call(d3.axisLeft(yScale).ticks(5).tickFormat(d => d));
  gridG.call(d3.axisLeft(yScale).ticks(5).tickSize(-innerW).tickFormat(""));

  svg.selectAll(".axis-label-x").remove();
  svg.selectAll(".axis-label-y").remove();
  svg.append("text").attr("class","axis-label axis-label-x")
    .attr("x", margin.left + innerW/2).attr("y", H - 4)
    .attr("text-anchor","middle").text("YEAR");
  svg.append("text").attr("class","axis-label axis-label-y")
    .attr("transform",`translate(10,${margin.top + innerH/2}) rotate(-90)`)
    .attr("text-anchor","middle").text("POWER SCORE (0–10)");

  eraBandsG.selectAll("*").remove();
  const [ed0, ed1] = getEffectiveDomain();
  const eraMarkers = [-2000,-1000,0,500,1000,1500,1800];
  eraMarkers.forEach(yr => {
    if (yr < ed0 || yr > ed1) return;
    const x = xScale(yr);
    eraBandsG.append("line")
      .attr("x1",x).attr("x2",x).attr("y1",0).attr("y2",innerH)
      .attr("stroke","#3a3d4a").attr("stroke-width",1).attr("stroke-dasharray","4,4").attr("opacity",0.5);
    eraBandsG.append("text").attr("class","era-label-text")
      .attr("x",x+3).attr("y",12).text(formatYear(yr));
  });

  areaG.selectAll("*").remove();
  if (soloEmpire) {
    const emp = EMPIRES.find(e => e.name === soloEmpire);
    if (emp) {
      const gradId = "area-grad-" + emp.name.replace(/\s+/g,"_");
      let defs2 = svg.select("defs");
      if (defs2.empty()) defs2 = svg.insert("defs","g");
      defs2.selectAll("#" + gradId).remove();
      const grad = defs2.append("linearGradient")
        .attr("id", gradId).attr("x1","0").attr("y1","0").attr("x2","0").attr("y2","1");
      grad.append("stop").attr("offset","0%").attr("stop-color", emp.color).attr("stop-opacity", 0.22);
      grad.append("stop").attr("offset","100%").attr("stop-color", emp.color).attr("stop-opacity", 0);
      areaG.append("path")
        .datum(getPointsInRange(emp))
        .attr("fill", `url(#${gradId})`)
        .attr("d", areaGen);
    }
  }

  const eventsG_sel = g.selectAll(".event-marker").data(showEvents ? EVENTS.filter(ev => { const [x0,x1]=getEffectiveDomain(); return ev.year>=x0&&ev.year<=x1; }) : []);
  eventsG_sel.exit().remove();
  const evEnter = eventsG_sel.enter().append("g").attr("class","event-marker");
  evEnter.append("line").attr("y1",0).attr("stroke-dasharray","2,6");
  evEnter.append("polygon").attr("class","event-tick").attr("points","-5,-14 5,-14 0,-5");
  const evMerge = eventsG_sel.merge(evEnter);
  evMerge.attr("transform", d => `translate(${xScale(d.year)},0)`);
  evMerge.select("line").attr("y1",0).attr("y2",innerH);
  evMerge.on("mouseover", function(event, d) {
    const evTip = document.getElementById("event-tooltip");
    if (!this.classList.contains("ev-active")) {
      evTip.innerHTML = `<div class="event-tip-label">${d.label}</div><div class="event-tip-year">${formatYear(d.year)}</div>`;
      const [mx, my] = d3.pointer(event, document.body);
      positionTooltip(evTip, mx, my);
      evTip.classList.add("visible");
    }
  }).on("mouseleave", function() {
    if (!this.classList.contains("ev-active")) {
      document.getElementById("event-tooltip").classList.remove("visible");
    }
  }).on("click", function(event, d) {
    event.stopPropagation();
    const evTip = document.getElementById("event-tooltip");
    const isActive = this.classList.contains("ev-active");
    g.selectAll(".event-marker").classed("ev-active", false);
    if (!isActive) {
      this.classList.add("ev-active");
      evTip.innerHTML = `<div class="event-tip-label">${d.label}</div><div class="event-tip-year">${formatYear(d.year)}</div><div class="event-tip-desc">${d.desc}</div>`;
      const [mx, my] = d3.pointer(event, document.body);
      positionTooltip(evTip, mx, my);
      evTip.classList.add("visible");
    } else {
      evTip.classList.remove("visible");
    }
  });

  const visible = EMPIRES.filter(isVisible);

  const noResults = document.getElementById("chart-no-results");
  noResults.style.display = visible.length === 0 ? "flex" : "none";

  const linesSel = linesG.selectAll(".empire-line").data(visible, d => d.name);
  linesSel.exit().remove();
  const linesEnter = linesSel.enter().append("path").attr("class","empire-line");
  const linesMerge = linesEnter.merge(linesSel);
  linesMerge
    .attr("d", d => lineGen(getPointsInRange(d)))
    .attr("stroke", d => d.color)
    .attr("stroke-opacity", d => getLineOpacity(d))
    .attr("stroke-width", d => (soloEmpire === d.name || compareEmpire === d.name) ? 2.8 : 1.5)
    .on("mousemove", (event, d) => showTooltip(event, d))
    .on("mouseleave", hideTooltip)
    .on("click", (event, d) => {
      if (event.shiftKey && soloEmpire && soloEmpire !== d.name) {
        compareEmpire = compareEmpire === d.name ? null : d.name;
        if (compareEmpire) zoomToCompare();
        render();
        updateLegendActive();
        updateInfoPanel();
      } else {
        compareEmpire = null;
        if (_lastEventWasTouch && soloEmpire === d.name) return;
        toggleSolo(d.name);
      }
    });

  dotsG.selectAll("*").remove();
  if (soloEmpire || searchTerm) {
    const dotEmpires = soloEmpire
      ? visible.filter(e => e.name === soloEmpire)
      : visible.filter(e => e.name.toLowerCase().includes(searchTerm));
    dotEmpires.forEach(empire => {
      empire.points.filter(p => p[0] >= xRange[0] && p[0] <= xRange[1]).forEach(p => {
        const desc = POINT_DESCS[empire.name + "|" + Math.round(p[0])];
        dotsG.append("circle")
          .datum({ empire, p, desc })
          .attr("cx", xScale(p[0])).attr("cy", yScale(p[1]))
          .attr("r", 4)
          .attr("fill", empire.color)
          .attr("stroke", "#0b0c10").attr("stroke-width", 1)
          .attr("opacity", 0.9)
          .style("cursor", desc ? "pointer" : "default")
          .on("mouseover", function(event, d) {
            if (!d.desc) return;
            const evTip = document.getElementById("event-tooltip");
            if (evTip.classList.contains("dot-pinned")) return;
            evTip.innerHTML = `<div class="event-tip-label">${d.empire.name}</div><div class="event-tip-year">${formatYear(d.p[0])}</div><div class="event-tip-desc">${d.desc}</div>`;
            const [mx, my] = d3.pointer(event, document.body);
            positionTooltip(evTip, mx, my);
            evTip.classList.add("visible");
          })
          .on("mouseleave", function() {
            const evTip = document.getElementById("event-tooltip");
            if (!evTip.classList.contains("dot-pinned")) evTip.classList.remove("visible");
          })
          .on("click", function(event, d) {
            event.stopPropagation();
            if (!d.desc) return;
            const evTip = document.getElementById("event-tooltip");
            const isPinned = evTip.classList.contains("dot-pinned") && evTip._pinnedDot === this;
            evTip.classList.remove("dot-pinned", "visible");
            evTip._pinnedDot = null;
            if (!isPinned) {
              evTip.innerHTML = `<div class="event-tip-label">${d.empire.name}</div><div class="event-tip-year">${formatYear(d.p[0])}</div><div class="event-tip-desc">${d.desc}</div>`;
              const [mx, my] = d3.pointer(event, document.body);
              positionTooltip(evTip, mx, my);
              evTip.classList.add("visible", "dot-pinned");
              evTip._pinnedDot = this;
            }
          });
      });
    });
  }

  labelsG.selectAll("*").remove();
  if (showLabels) {
    const labelEmpires = soloEmpire
      ? visible.filter(e => e.name === soloEmpire)
      : searchTerm ? visible.filter(e => e.name.toLowerCase().includes(searchTerm)) : visible;
    labelEmpires.forEach(empire => {
      const pts = getPointsInRange(empire);
      if (!pts.length) return;
      const peakPt = pts.reduce((a,b) => b[1] > a[1] ? b : a);
      labelsG.append("text")
        .attr("x", xScale(peakPt[0])).attr("y", yScale(peakPt[1]) - 7)
        .attr("text-anchor","middle")
        .attr("fill", empire.color)
        .attr("font-family","'Crimson Pro', serif")
        .attr("font-size", soloEmpire ? "12px" : "9px")
        .attr("font-style","italic")
        .attr("opacity", soloEmpire || searchTerm ? 1 : 0.7)
        .text(empire.name);
    });
  }

  peaksG.selectAll("*").remove();
  const peakEmpires = soloEmpire ? visible.filter(e => e.name === soloEmpire || e.name === compareEmpire) : visible;
  peakEmpires.forEach(emp => {
    const pts = getPointsInRange(emp);
    if (!pts.length) return;
    const peak = pts.reduce((a,b) => b[1] > a[1] ? b : a);
    peaksG.append("text")
      .attr("x", xScale(peak[0])).attr("y", yScale(peak[1]) - 2)
      .attr("text-anchor","middle")
      .attr("font-size","10px")
      .attr("fill", emp.color)
      .attr("opacity", soloEmpire ? 1 : 0.6)
      .attr("class","peak-marker")
      .text("◆")
      .append("title").text(`${emp.name} peak: ${formatYear(peak[0])}`);
  });

  crosshairG.selectAll("*").remove();
  if (!soloEmpire) {
    crosshairG.append("rect")
      .attr("width", innerW).attr("height", innerH)
      .attr("fill", "transparent")
      .attr("class", "crosshair-overlay")
      .on("mousemove", function(event) {
        const [px] = d3.pointer(event);
        const mouseX = xScale.invert(px);
        crosshairG.selectAll(".crosshair-line").remove();
        crosshairG.append("line")
          .attr("class","crosshair-line")
          .attr("x1",px).attr("x2",px).attr("y1",0).attr("y2",innerH)
          .attr("stroke","var(--border)").attr("stroke-width",1).attr("stroke-dasharray","3,3").attr("opacity",0.5);
      })
      .on("mouseleave", () => crosshairG.selectAll(".crosshair-line").remove());
  }

  updateLegend(visible);
}

// ── Event Listeners ────────────────────────────────────────────────────────
document.getElementById("region-tabs").addEventListener("click", e => {
  if (!e.target.classList.contains("tab")) return;
  document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
  e.target.classList.add("active");
  activeRegion = e.target.dataset.region;
  soloEmpire = null;
  compareEmpire = null;
  viewDomain = null;
  stopPlay();
  playYear = null;
  updateZoomButton();
  render();
  buildMinimap();
  encodeState();
});

document.getElementById("era-select").addEventListener("change", e => {
  xRange = e.target.value ? (ERAS[e.target.value] || null) : null;
  soloEmpire = null;
  compareEmpire = null;
  viewDomain = null;
  stopPlay();
  playYear = null;
  updateZoomButton();
  render();
  encodeState();
});

document.getElementById("toggle-labels").addEventListener("change", e => {
  showLabels = e.target.checked; render();
});

document.getElementById("toggle-events").addEventListener("change", e => {
  showEvents = e.target.checked; render();
});

const searchInput = document.getElementById("empire-search");
const clearBtn = document.getElementById("clear-search");
searchInput.addEventListener("input", e => {
  searchTerm = e.target.value.toLowerCase().trim();
  clearBtn.classList.toggle("visible", searchTerm.length > 0);
  soloEmpire = null;
  render();
});
clearBtn.addEventListener("click", () => {
  searchInput.value = "";
  searchTerm = "";
  clearBtn.classList.remove("visible");
  render();
});

document.getElementById("zoom-reset-btn").addEventListener("click", () => {
  if (soloEmpire) toggleSolo(soloEmpire);
});

window.addEventListener("resize", () => { resize(); buildMinimap(); });

document.getElementById("play-btn").addEventListener("click", () => {
  if (isPlaying) stopPlay(); else startPlay();
});
document.getElementById("play-reset").addEventListener("click", () => {
  stopPlay();
  playYear = null;
  document.getElementById("play-year").textContent = "—";
  document.getElementById("play-scrubber").value = 0;
  render();
});
document.getElementById("play-scrubber").addEventListener("input", e => {
  stopPlay();
  const [start, end] = getPlayRange();
  playYear = start + (parseFloat(e.target.value) / 100) * (end - start);
  document.getElementById("play-year").textContent = formatYear(playYear);
  render();
});

document.addEventListener("click", () => {
  const evTip = document.getElementById("event-tooltip");
  if (evTip) {
    evTip.classList.remove("visible");
    evTip.classList.remove("dot-pinned");
    evTip._pinnedDot = null;
  }
  g.selectAll(".event-marker").classed("ev-active", false);
});

document.getElementById("info-close").addEventListener("click", () => {
  if (soloEmpire) toggleSolo(soloEmpire);
});

document.getElementById("info-share-x").addEventListener("click", () => {
  const name = document.getElementById("info-name").textContent;
  const text = encodeURIComponent("I just explored the rise and fall of " + name + " on The Epoch Institute — an interactive civilisational research project.");
  window.open("https://twitter.com/intent/tweet?text=" + text + "&url=https%3A%2F%2Fthe-epoch-institute.org&hashtags=history%2Cempires%2CEpochInstitute", "_blank");
});
document.getElementById("info-share-li").addEventListener("click", () => {
  window.open("https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fthe-epoch-institute.org", "_blank");
});


document.addEventListener("keydown", e => {
  if (e.key === "Escape") {
    if (soloEmpire) toggleSolo(soloEmpire);
    return;
  }
  if (e.key === " " && activeRegion && xRange) {
    e.preventDefault();
    if (isPlaying) stopPlay(); else startPlay();
    return;
  }
  if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
    const vis = EMPIRES.filter(isVisible);
    if (!vis.length) return;
    const idx = soloEmpire ? vis.findIndex(ev => ev.name === soloEmpire) : -1;
    const next = e.key === "ArrowRight"
      ? (idx + 1) % vis.length
      : (idx - 1 + vis.length) % vis.length;
    if (soloEmpire) { soloEmpire = null; viewDomain = null; }
    compareEmpire = null;
    toggleSolo(vis[next].name);
  }
});

// ── Init ───────────────────────────────────────────────────────────────────
decodeState();
requestAnimationFrame(() => { resize(); buildMinimap(); });
</script>
