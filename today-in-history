<body>

<section id="today-in-history">
  <div class="tih-page-header">
    <span class="hero-ornament"></span>
    <h2 class="research-title" id="tih-heading">Today in History</h2>
    <p class="research-subtitle" id="tih-subheading">Loading&hellip;</p>
  </div>

  <div class="tih-full-wrap">
    <div id="tih-pinned-wrap" style="display:none;"></div>
    <p class="tih-full-loading" id="tih-loading" style="display:none;"></p>
    <div class="tih-grid" id="tih-grid">
      <div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div>
      <div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div>
      <div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div>
    </div>
    <div class="tih-pagination" id="tih-pagination" style="display:none;"></div>
  </div>

  <div id="tih-tooltip" class="tih-share-tooltip"></div>
</section>

<script src="/shared-data.js"></script>
<script src="/shared-nav.js"></script>
<script>
initNav('today');

var cachedData    = null;
var cachedIntlDay = null;
var currentDay    = null;
var currentPage   = 1;
var dayEvents     = [];
var PER_PAGE      = 15;
var tooltipTimer;
var activeDropdown = null;
var PAGE_URL      = 'https://the-epoch-institute.org/today-in-history';

var SHARE_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
var GLOBE_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';

function getDayKey() {
  var n = new Date();
  return String(n.getMonth() + 1).padStart(2, '0') + '-' + String(n.getDate()).padStart(2, '0');
}

function getDayLabels() {
  var n = new Date();
  return {
    dow:  n.toLocaleDateString('en-GB', { weekday: 'long' }),
    full: n.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  };
}

function totalPages() { return Math.max(1, Math.ceil(dayEvents.length / PER_PAGE)); }

function getPaginationItems(cur, tot) {
  var set = {}, i;
  set[1] = set[tot] = true;
  for (i = Math.max(2, cur - 2); i <= Math.min(tot - 1, cur + 2); i++) set[i] = true;
  var nums = Object.keys(set).map(Number).sort(function(a, b) { return a - b; });
  var out = [];
  for (i = 0; i < nums.length; i++) {
    if (i > 0 && nums[i] - nums[i - 1] > 1) out.push('...');
    out.push(nums[i]);
  }
  return out;
}

function closeAllDropdowns() {
  if (activeDropdown) { activeDropdown.style.display = 'none'; activeDropdown = null; }
}

document.addEventListener('click', function(e) {
  if (activeDropdown && !activeDropdown.parentNode.contains(e.target)) closeAllDropdowns();
});

function showTooltip(msg) {
  var el = document.getElementById('tih-tooltip');
  el.textContent = msg;
  el.classList.add('visible');
  clearTimeout(tooltipTimer);
  tooltipTimer = setTimeout(function() { el.classList.remove('visible'); }, 2200);
}

function scrollToGrid() {
  var grid = document.getElementById('tih-grid');
  var top = grid.getBoundingClientRect().top + window.pageYOffset - 80;
  window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
}

function renderPage(page, scroll) {
  currentPage = page;
  var start = (page - 1) * PER_PAGE;
  var slice = dayEvents.slice(start, start + PER_PAGE);
  var tot   = totalPages();
  var grid  = document.getElementById('tih-grid');
  var pag   = document.getElementById('tih-pagination');

  grid.innerHTML = slice.map(function(ev, i) {
    var ddId = 'tih-dd-' + (start + i);
    return '<div class="tih-event-card">' +
      '<button class="tih-share-btn" data-dd="' + ddId + '" aria-label="Share this event">' + SHARE_SVG + '</button>' +
      '<div class="tih-share-dropdown" id="' + ddId + '" style="display:none;">' +
        '<button class="tih-share-dd-item" data-action="tweet" data-idx="' + (start + i) + '">Post on X</button>' +
        '<button class="tih-share-dd-item" data-action="copy" data-idx="' + (start + i) + '">Copy link</button>' +
      '</div>' +
      '<p class="tih-event-year">' + escHtml(ev.yearDisplay || String(ev.year)) + '</p>' +
      '<p class="tih-event-title">' + escHtml(ev.title) + '</p>' +
      '<p class="tih-event-desc">'  + escHtml(ev.description) + '</p>' +
    '</div>';
  }).join('');

  grid.querySelectorAll('.tih-share-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var ddId = btn.dataset.dd;
      var idx  = parseInt(ddId.replace('tih-dd-', ''), 10);
      var ev   = dayEvents[idx];
      if (navigator.share) {
        navigator.share({ title: ev.title, text: composeTweet(ev), url: PAGE_URL }).catch(function() {});
        return;
      }
      var dd = document.getElementById(ddId);
      if (dd.style.display === 'none') {
        closeAllDropdowns();
        dd.style.display = '';
        activeDropdown = dd;
      } else {
        closeAllDropdowns();
      }
    });
  });

  grid.querySelectorAll('.tih-share-dd-item').forEach(function(item) {
    item.addEventListener('click', function(e) {
      e.stopPropagation();
      var action = item.dataset.action;
      var ev     = dayEvents[parseInt(item.dataset.idx, 10)];
      if (action === 'tweet') {
        window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(composeTweet(ev) + '\n\nhttps://the-epoch-institute.org/today-in-history'), '_blank');
        closeAllDropdowns();
      } else if (action === 'copy') {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(PAGE_URL).then(function() {
            var orig = item.textContent;
            item.textContent = '✓ Copied!';
            setTimeout(function() { item.textContent = orig; }, 2000);
          }).catch(function() {});
        }
        setTimeout(closeAllDropdowns, 2100);
      }
    });
  });

  var items = getPaginationItems(page, tot);
  var html  = '';
  if (page > 1)
    html += '<button class="tih-pg-btn prev-next" data-pg="' + (page - 1) + '">← Prev</button>';
  items.forEach(function(p) {
    if (p === '...')
      html += '<span class="tih-pg-ellipsis">…</span>';
    else
      html += '<button class="tih-pg-btn' + (p === page ? ' active' : '') +
        '" data-pg="' + p + '">' + p + '</button>';
  });
  if (page < tot)
    html += '<button class="tih-pg-btn prev-next" data-pg="' + (page + 1) + '">Next →</button>';

  pag.innerHTML = html;
  pag.querySelectorAll('.tih-pg-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      renderPage(parseInt(btn.dataset.pg, 10), true);
    });
  });

  pag.style.display  = tot > 1 ? 'flex' : 'none';
  if (scroll) scrollToGrid();
}

function renderDay(key, intlDay) {
  currentDay  = key;
  currentPage = 1;
  dayEvents   = (cachedData && cachedData[key]) || [];

  var labels = getDayLabels();
  document.getElementById('tih-subheading').innerHTML =
    '<span class="tih-date-sep"></span>' +
    '<span class="tih-date-dow">' + escHtml(labels.dow) + '</span>' +
    '<span class="tih-date-full">' + escHtml(labels.full) + '</span>' +
    '<span class="tih-date-sep"></span>';

  var pinnedWrap = document.getElementById('tih-pinned-wrap');
  if (intlDay) {
    pinnedWrap.innerHTML =
      '<div class="tih-pinned-card">' +
        '<span class="tih-pinned-icon">' + GLOBE_SVG + '</span>' +
        '<p class="tih-pinned-label">Today\'s International Day</p>' +
        '<p class="tih-pinned-title">' + escHtml(intlDay.name) + '</p>' +
        '<p class="tih-pinned-desc">' + escHtml(intlDay.description) + '</p>' +
      '</div>';
    pinnedWrap.style.display = '';
  } else {
    pinnedWrap.style.display = 'none';
    pinnedWrap.innerHTML = '';
  }

  var loading = document.getElementById('tih-loading');
  var grid    = document.getElementById('tih-grid');
  var pag     = document.getElementById('tih-pagination');

  if (!dayEvents.length) {
    loading.textContent   = 'No events found for ' + labels.full + '.';
    loading.style.display = '';
    grid.style.display    = 'none';
    pag.style.display     = 'none';
    return;
  }

  loading.style.display = 'none';
  renderPage(1, false);
}

function showTihError() {
  var grid = document.getElementById('tih-grid');
  grid.innerHTML = '<div class="tih-error-state"><p>Events could not be loaded.</p><button class="tih-retry-btn" id="tih-retry-btn">Try again</button></div>';
  grid.style.display = '';
  document.getElementById('tih-loading').style.display = 'none';
  document.getElementById('tih-retry-btn').addEventListener('click', function() {
    grid.innerHTML = '<div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div><div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div><div class="tih-skeleton-card"><div class="tih-sk-year"></div><div class="tih-sk-title"></div><div class="tih-sk-desc"></div></div>';
    loadTihData();
  });
}

function loadTihData() {
  var timeout = new Promise(function(_, rej) {
    setTimeout(function() { rej(new Error('timeout')); }, 8000);
  });
  Promise.race([
    Promise.all([
      fetch('/data/history.json').then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); }),
      fetch('/data/international-days.json').then(function(r) { return r.ok ? r.json() : {}; }).catch(function() { return {}; })
    ]),
    timeout
  ]).then(function(results) {
    cachedData    = results[0];
    cachedIntlDay = results[1];
    renderDay(getDayKey(), cachedIntlDay[getDayKey()] || null);
  }).catch(function() {
    showTihError();
  });
}

loadTihData();

// Midnight rollover: re-render if day changes
setInterval(function() {
  var key = getDayKey();
  if (key !== currentDay && cachedData) renderDay(key, (cachedIntlDay || {})[key] || null);
}, 30000);
</script>

</body>
</html>
