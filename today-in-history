<!DOCTYPE html>
<html lang="en">
<head>
<script>(function(){var t=localStorage.getItem('epoch-theme');if(t==='light')document.documentElement.setAttribute('data-theme','light');else if(t==='dark')document.documentElement.setAttribute('data-theme','dark');})()</script>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Today in History — The Epoch Institute</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230d0d0d'/%3E%3Ctext x='16' y='23' font-family='serif' font-size='22' font-weight='700' fill='%23c9a84c' text-anchor='middle'%3EE%3C/text%3E%3C/svg%3E">
<meta name="description" content="Explore what happened throughout history on this very day — from ancient civilisations to modern milestones, curated by The Epoch Institute.">
<meta property="og:title" content="Today in History — The Epoch Institute">
<meta property="og:description" content="Historical events from across five millennia, surfaced for today's date.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://the-epoch-institute.org/today-in-history">
<link rel="canonical" href="https://the-epoch-institute.org/today-in-history">
<link rel="stylesheet" href="/shared.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
