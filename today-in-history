</head>
<body>

<section id="today-in-history">
  <span class="hero-ornament"></span>
  <h2 class="research-title" id="tih-heading">Today in History</h2>
  <p class="research-subtitle" id="tih-subheading">Loading…</p>

  <div class="tih-full-wrap">
    <p class="tih-full-loading" id="tih-loading">Loading events…</p>

    <div class="tih-carousel-outer" id="tih-carousel" style="display:none;">
      <button class="tih-nav-btn" id="tih-prev" aria-label="Previous event">‹</button>
      <div class="tih-carousel-window" id="tih-window">
        <div class="tih-carousel-track" id="tih-track"></div>
      </div>
      <button class="tih-nav-btn" id="tih-next" aria-label="Next event">›</button>
    </div>

    <p class="tih-counter" id="tih-counter" style="display:none;"></p>
  </div>
</section>

<script src="/shared-data.js"></script>
<script src="/shared-nav.js"></script>
<script>
initNav('today');

var cachedData = null;
var currentDay = null;
var currentIdx = 0;
var dayEvents  = [];

function getDayKey() {
  var n = new Date();
  return String(n.getMonth() + 1).padStart(2, '0') + '-' + String(n.getDate()).padStart(2, '0');
}

function getDayLabel() {
  return new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });
}

function getStep() {
  var card = document.querySelector('.tih-event-card');
  return card ? card.offsetWidth + 20 : 300;
}

function applyTransform(animate) {
  var track = document.getElementById('tih-track');
  if (!animate) track.style.transition = 'none';
  track.style.transform = 'translateX(' + -(currentIdx * getStep()) + 'px)';
  if (!animate) {
    track.offsetHeight; // force reflow
    track.style.transition = '';
  }
}

function updateNav() {
  document.getElementById('tih-prev').disabled = currentIdx === 0;
  document.getElementById('tih-next').disabled = currentIdx >= dayEvents.length - 1;
  document.getElementById('tih-counter').textContent =
    (currentIdx + 1) + ' / ' + dayEvents.length + ' events';
}

function goTo(idx) {
  currentIdx = Math.max(0, Math.min(idx, dayEvents.length - 1));
  applyTransform(true);
  updateNav();
}

function renderDay(key) {
  currentDay = key;
  currentIdx = 0;
  dayEvents  = (cachedData && cachedData[key]) || [];

  var label    = getDayLabel();
  document.getElementById('tih-subheading').textContent = label + ' — Today in History';

  var loading  = document.getElementById('tih-loading');
  var carousel = document.getElementById('tih-carousel');
  var counter  = document.getElementById('tih-counter');

  loading.style.display  = 'none';
  carousel.style.display = 'none';
  counter.style.display  = 'none';

  if (!dayEvents.length) {
    loading.textContent    = 'No events found for ' + label + '.';
    loading.style.display  = '';
    return;
  }

  document.getElementById('tih-track').innerHTML = dayEvents.map(function(ev, i) {
    return '<div class="tih-event-card" data-idx="' + i + '">' +
      '<p class="tih-event-year">' + escHtml(ev.yearDisplay || String(ev.year)) + '</p>' +
      '<p class="tih-event-title">' + escHtml(ev.title) + '</p>' +
      '<p class="tih-event-desc">' + escHtml(ev.description) + '</p>' +
    '</div>';
  }).join('');

  carousel.style.display = 'flex';
  counter.style.display  = '';
  applyTransform(false);
  updateNav();
}

// Nav buttons
document.getElementById('tih-prev').addEventListener('click', function() { goTo(currentIdx - 1); });
document.getElementById('tih-next').addEventListener('click', function() { goTo(currentIdx + 1); });

// Touch / swipe
(function() {
  var win    = document.getElementById('tih-window');
  var startX = 0;
  win.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
  win.addEventListener('touchend',   function(e) {
    var dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 50) goTo(currentIdx + (dx < 0 ? 1 : -1));
  });
})();

// Reposition on resize without animation
window.addEventListener('resize', function() {
  if (dayEvents.length) applyTransform(false);
});

// Keyboard navigation
document.addEventListener('keydown', function(e) {
  if (e.key === 'ArrowLeft')  goTo(currentIdx - 1);
  if (e.key === 'ArrowRight') goTo(currentIdx + 1);
});

// Load data
fetch('/data/history.json')
  .then(function(r) {
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  })
  .then(function(data) {
    cachedData = data;
    renderDay(getDayKey());
  })
  .catch(function() {
    var el = document.getElementById('tih-loading');
    el.style.display = '';
    el.textContent = 'Events unavailable — please run the data scraping script first.';
  });

// Midnight rollover: check every 30 s, re-render if day changes
setInterval(function() {
  var key = getDayKey();
  if (key !== currentDay && cachedData) renderDay(key);
}, 30000);
</script>

</body>
</html>
