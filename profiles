<style>
/* ── Profile search ── */
.profile-search-wrap {
  display: flex; align-items: center; gap: 8px;
  padding: 0 40px 24px; max-width: 540px; margin: 0;
}
.profile-search-input {
  flex: 1; background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 3px; padding: 9px 14px;
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.06em;
  color: var(--text); outline: none; transition: border-color 0.2s;
}
.profile-search-input::placeholder { color: var(--muted); opacity: 0.5; }
.profile-search-input:focus { border-color: var(--gold); }
.profile-search-clear {
  background: none; border: none; cursor: pointer;
  font-size: 14px; color: var(--muted); padding: 0 4px;
  display: none; transition: color 0.2s;
}
.profile-search-clear:hover { color: var(--gold); }
.profile-search-empty {
  padding: 0 40px 32px;
  font-family: 'Crimson Pro', Georgia, serif; font-size: 15px;
  color: var(--muted); opacity: 0.65;
}
@media (max-width: 600px) {
  .profile-search-wrap { padding: 0 16px 20px; }
  .profile-search-empty { padding: 0 16px 24px; }
}

/* ── Profiles page layout ── */
#profiles { min-height: 100vh; }
#profiles .explorer-header { padding-top: 100px; }
</style>
