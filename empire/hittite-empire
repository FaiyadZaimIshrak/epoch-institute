        <h1 class="profile-detail-name">Hittite Empire</h1>
        <div class="info-stats" style="margin-top:10px;">
          <div class="info-stat"><span class="info-stat-label">Peak</span><span class="info-stat-val">1300 BCE</span></div>
          <div class="info-stat"><span class="info-stat-label">Duration</span><span class="info-stat-val">472 yrs</span></div>
