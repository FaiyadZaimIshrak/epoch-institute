        <h1 class="profile-detail-name">Songhai Empire</h1>
        <div class="info-stats" style="margin-top:10px;">
          <div class="info-stat"><span class="info-stat-label">Peak</span><span class="info-stat-val">1510 CE</span></div>
          <div class="info-stat"><span class="info-stat-label">Duration</span><span class="info-stat-val">170 yrs</span></div>
